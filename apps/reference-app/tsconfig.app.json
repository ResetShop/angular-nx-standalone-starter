{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"outDir": "./dist/out-tsc",
		"types": ["node"]
	},
	"include": ["src/**/*.ts"],
	"exclude": [
		"jest.config.ts",
		"src/test-setup.ts",
		"src/test-utils.ts",
		"src/**/*.test.ts",
		"src/**/*.spec.ts",
		"**/*.stories.ts",
		"**/*.stories.js",
		"src/api/integration/**"
	]
}
