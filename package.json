	"scripts": {
		"postinstall": "npm run config && npm run drizzle:push-migrations && npm run drizzle:seed",
		"config": "tsx ./scripts/set-environment.ts",
		"serve:ssr": "node dist/app/server/server.mjs",
		"prepare": "husky",
		"ci": "npm run stylelint && npm run lint && npm run test && npm run build && npm run storybook:build",
		"dev": "nx serve",
		"build": "nx build",
		"storybook": "nx run app:storybook",
		"storybook:build": "nx run app:build-storybook",
		"lint": "nx lint --skip-nx-cache",
		"stylelint": "nx stylelint app --skip-nx-cache",
		"test": "nx test --skip-nx-cache",
		"test:watch": "nx test --watch",
		"test:ui": "nx test --configuration=ui -- --ui",
		"test:e2e": "nx run app:e2e",
		"drizzle:create-migrations": "drizzle-kit generate",
		"drizzle:push-migrations": "drizzle-kit push",
		"drizzle:seed": "tsx ./src/db/seed.ts",
		"drizzle:seed:local": "node --env-file=.env --import tsx ./src/db/seed.ts"
	},
	"private": true,
