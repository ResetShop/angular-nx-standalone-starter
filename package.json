{
	"name": "@app/source",
	"type": "module",
	"version": "1.0.0-next.0",
	"license": "CC-BY-SA 4.0",
	"imports": {
		"#tailwind-theme": "./tailwind.config.css"
	},
	"engines": {
		"node": "^20.19.0 || ^22.19.0"
	},
	"scripts": {
		"postinstall": "node scripts/setup-skills.mjs && npm run drizzle:push-migrations && npm run drizzle:seed",
		"serve:ssr": "node dist/reference-app/server/server.mjs",
		"prepare": "husky",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"ci": "prettier --check . && nx run-many -t stylelint lint typecheck --skip-nx-cache && nx run-many -t test test-integration build build-storybook --skip-nx-cache",
		"dev": "nx serve reference-app",
		"build": "nx build reference-app",
		"storybook": "nx run reference-app:storybook",
		"storybook:build": "nx run reference-app:build-storybook",
		"lint": "nx run-many -t lint --skip-nx-cache",
		"stylelint": "nx stylelint reference-app --skip-nx-cache",
		"typecheck": "nx run-many -t typecheck --skip-nx-cache",
		"test": "nx run-many -t test --skip-nx-cache",
		"test:integration": "nx test-integration reference-app --skip-nx-cache",
		"test:watch": "nx run reference-app:test --watch",
		"test:ui": "nx run reference-app:test --configuration=ui -- --ui",
		"test:e2e": "nx run reference-app:e2e",
		"generate:app": "nx g @resetshop/generators:app",
		"drizzle:create-migrations": "drizzle-kit generate",
		"drizzle:push-migrations": "drizzle-kit push",
		"drizzle:seed": "tsx --tsconfig apps/reference-app/tsconfig.json ./apps/reference-app/src/db/seed.ts",
		"drizzle:seed:local": "tsx --env-file=.env --tsconfig apps/reference-app/tsconfig.json ./apps/reference-app/src/db/seed.ts",
		"sync:permissions": "tsx --tsconfig apps/reference-app/tsconfig.json ./apps/reference-app/src/db/sync-permissions.ts",
		"sync:permissions:local": "tsx --env-file=.env --tsconfig apps/reference-app/tsconfig.json ./apps/reference-app/src/db/sync-permissions.ts"
	},
	"private": true,
	"dependencies": {
		"@angular-devkit/build-angular": "21.1.5",
		"@angular/cdk": "21.1.6",
		"@angular/common": "21.1.6",
		"@angular/compiler": "21.1.6",
		"@angular/core": "21.1.6",
		"@angular/forms": "21.1.6",
		"@angular/platform-browser": "21.1.6",
		"@angular/platform-browser-dynamic": "21.1.6",
		"@angular/platform-server": "21.1.6",
		"@angular/router": "21.1.6",
		"@angular/ssr": "21.1.5",
		"@floating-ui/dom": "^1.6.0",
		"@hono/node-server": "^1.19.7",
		"@hono/zod-openapi": "^1.2.0",
		"@hono/zod-validator": "^0.7.6",
		"@ng-icons/core": "^33.0.0",
		"@ng-icons/feather-icons": "^33.0.0",
		"@ng-primitives/mcp": "^0.110.1",
		"@ngrx/signals": "^21.0.1",
		"@tailwindcss/postcss": "^4.1.18",
		"@tanstack/angular-table": "^8.21.3",
		"awilix": "^12.0.5",
		"bcryptjs": "^3.0.3",
		"drizzle-orm": "^0.45.1",
		"hono": "^4.11.1",
		"hono-rate-limiter": "^0.5.3",
		"nodemailer": "^7.0.13",
		"paseto": "^3.1.4",
		"pg": "^8.16.3",
		"postcss": "^8.5.6",
		"rxjs": "~7.8.0",
		"tailwindcss": "^4.1.18",
		"zod": "^4.2.1"
	},
	"devDependencies": {
		"@analogjs/vite-plugin-angular": "2.3.1-beta.1",
		"@analogjs/vitest-angular": "2.3.1-beta.1",
		"@angular-devkit/core": "21.1.5",
		"@angular-devkit/schematics": "21.1.5",
		"@angular/build": "21.1.5",
		"@angular/cli": "21.1.5",
		"@angular/compiler-cli": "21.1.6",
		"@angular/language-service": "21.1.6",
		"@eslint/js": "^9.39.2",
		"@nx/angular": "22.6.0",
		"@nx/devkit": "22.6.0",
		"@nx/eslint": "22.6.0",
		"@nx/eslint-plugin": "22.6.0",
		"@nx/js": "22.6.0",
		"@nx/playwright": "22.6.0",
