{
	"name": "@app/source",
	"type": "module",
	"version": "1.0.0",
	"license": "Apache-2.0",
	"description": "Fork-ready Nx monorepo starter: an SSR-ready Angular 21+ frontend and a Hono backend API, with NgRx Signal Store, a Drizzle/Postgres data layer, and PASETO auth + RBAC.",
	"author": {
		"name": "ResetShop",
		"url": "https://github.com/ResetShop"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ResetShop/angular-nx-standalone-starter.git"
	},
	"homepage": "https://github.com/ResetShop/angular-nx-standalone-starter#readme",
	"bugs": {
		"url": "https://github.com/ResetShop/angular-nx-standalone-starter/issues"
	},
	"keywords": [
		"angular",
		"nx",
		"monorepo",
		"hono",
		"ssr",
		"typescript",
		"drizzle",
		"postgres",
		"ngrx",
		"paseto",
		"starter",
		"template"
	],
	"imports": {
		"#tailwind-theme": "./tailwind.config.css"
	},
	"engines": {
		"node": "^24.18.0"
	},
	"scripts": {
		"postinstall": "node scripts/setup-skills.mjs",
		"serve:ssr": "node dist/reference-app/server/server.mjs",
		"prepare": "husky",
		"format": "prettier --write --cache .",
		"format:check": "prettier --check --cache .",
		"ci": "nx run-many -t check stylelint lint typecheck --skip-nx-cache && nx run-many -t test test-integration build build-storybook --skip-nx-cache --maxParallel=3",
		"ci:verify": "nx run-many -t check stylelint lint typecheck && nx run-many -t test test-integration build build-storybook --maxParallel=3",
		"dev": "nx serve reference-app",
		"build": "nx build reference-app --skip-nx-cache",
		"storybook": "nx run reference-app:storybook",
		"storybook:build": "nx run reference-app:build-storybook",
		"lint": "nx run-many -t lint --skip-nx-cache",
		"stylelint": "nx stylelint reference-app --skip-nx-cache",
		"typecheck": "nx run-many -t typecheck --skip-nx-cache",
		"test": "nx run-many -t test --skip-nx-cache",
		"test:integration": "nx test-integration reference-app --skip-nx-cache",
		"test:watch": "nx run reference-app:test --watch",
		"test:ui": "nx run reference-app:test --configuration=ui -- --ui",
		"test:e2e": "nx run reference-app:e2e",
		"test:e2e:ui": "nx run reference-app:e2e -- --ui",
		"generate:app": "nx g @resetshop/generators:app",
		"fork:init": "node scripts/fork-init.mjs",
		"upstream:pull": "node scripts/upstream-pull.mjs",
		"drizzle:create-migrations": "tsx --tsconfig apps/reference-app/tsconfig.json ./node_modules/drizzle-kit/bin.cjs generate",
		"drizzle:push-migrations": "tsx --tsconfig apps/reference-app/tsconfig.json ./node_modules/drizzle-kit/bin.cjs push",
		"drizzle:seed": "tsx --tsconfig apps/reference-app/tsconfig.json ./apps/reference-app/src/db/seed.ts",
		"drizzle:seed:local": "tsx --env-file=.env --tsconfig apps/reference-app/tsconfig.json ./apps/reference-app/src/db/seed.ts",
		"sync:permissions": "tsx --tsconfig apps/reference-app/tsconfig.json ./apps/reference-app/src/db/sync-permissions.ts",
		"sync:permissions:local": "tsx --env-file=.env --tsconfig apps/reference-app/tsconfig.json ./apps/reference-app/src/db/sync-permissions.ts"
	},
	"private": true,
	"dependencies": {
		"@angular-devkit/build-angular": "21.2.13",
		"@angular/cdk": "21.2.13",
		"@angular/common": "21.2.15",
		"@angular/compiler": "21.2.15",
		"@angular/core": "21.2.15",
		"@angular/forms": "21.2.15",
		"@angular/platform-browser": "21.2.15",
		"@angular/platform-browser-dynamic": "21.2.15",
		"@angular/platform-server": "21.2.15",
		"@angular/router": "21.2.15",
		"@angular/ssr": "21.2.13",
		"@floating-ui/dom": "^1.6.0",
		"@hono/node-server": "^1.19.7",
		"@hono/zod-openapi": "^1.2.0",
		"@hono/zod-validator": "^0.7.6",
		"@ng-icons/core": "^33.0.0",
		"@ng-icons/feather-icons": "^33.0.0",
		"@ng-primitives/mcp": "^0.110.1",
		"@ngrx/signals": "^21.0.1",
		"@tailwindcss/postcss": "^4.1.18",
		"@tanstack/angular-table": "^8.21.3",
		"awilix": "^12.0.5",
		"bcryptjs": "^3.0.3",
		"drizzle-orm": "^0.45.1",
		"hono": "^4.11.1",
		"hono-rate-limiter": "^0.5.3",
		"nodemailer": "^7.0.13",
		"paseto": "^3.1.4",
		"pg": "^8.16.3",
		"postcss": "^8.5.6",
		"rxjs": "~7.8.0",
		"tailwindcss": "^4.1.18",
		"zod": "^4.2.1"
	},
	"devDependencies": {
		"@analogjs/vite-plugin-angular": "2.3.1-beta.1",
		"@analogjs/vitest-angular": "2.3.1-beta.1",
		"@angular-devkit/core": "21.2.13",
		"@angular-devkit/schematics": "21.2.13",
		"@angular/build": "21.2.13",
		"@angular/cli": "21.2.13",
		"@angular/compiler-cli": "21.2.15",
		"@angular/language-service": "21.2.15",
		"@eslint/js": "^9.39.2",
		"@nx/angular": "22.7.5",
		"@nx/devkit": "22.7.5",
		"@nx/eslint": "22.7.5",
		"@nx/eslint-plugin": "22.7.5",
		"@nx/js": "22.7.5",
		"@nx/playwright": "22.7.5",
		"@nx/storybook": "22.7.5",
		"@nx/vite": "22.7.5",
		"@nx/vitest": "22.7.5",
		"@nx/web": "22.7.5",
		"@nx/workspace": "22.7.5",
		"@playwright/test": "^1.57.0",
		"@resetshop/generators": "file:packages/generators",
		"@schematics/angular": "21.2.13",
		"@storybook/addon-docs": "10.1.10",
		"@storybook/addon-styling-webpack": "^3.0.0",
		"@storybook/angular": "10.1.10",
		"@stylistic/eslint-plugin": "^5.6.1",
		"@swc-node/register": "1.11.1",
		"@swc/core": "~1.15.7",
		"@swc/helpers": "0.5.18",
		"@testing-library/angular": "^19.1.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^24.13.3",
		"@types/nodemailer": "^7.0.9",
		"@types/pg": "^8.16.0",
		"@typescript-eslint/utils": "^8.50.0",
		"@vitest/eslint-plugin": "^1.6.9",
		"@vitest/ui": "^4.0.16",
		"angular-eslint": "21.2.0",
		"baseline-browser-mapping": "^2.9.11",
		"drizzle-kit": "^0.31.8",
		"embedded-postgres": "^17.9.0-beta.17",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-no-barrel-files": "^1.2.2",
		"eslint-plugin-playwright": "^2.4.0",
		"eslint-plugin-storybook": "10.1.10",
		"eslint-plugin-testing-library": "^7.15.3",
		"happy-dom": "^20.0.11",
		"husky": "^9.1.7",
		"ng-primitives": "^0.110.1",
		"nx": "22.7.5",
		"nx-stylelint": "^18.0.2",
		"only-allow": "^1.2.2",
		"prettier": "^3.7.4",
		"prettier-plugin-organize-attributes": "^1.0.0",
		"prettier-plugin-organize-imports": "^4.3.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"pretty-quick": "^4.2.2",
		"storybook": "10.1.10",
		"stylelint": "^16.26.1",
		"stylelint-config-recommended": "^17.0.0",
		"stylelint-config-standard": "^39.0.0",
		"stylelint-config-tailwindcss": "^1.0.0",
		"ts-node": "10.9.2",
		"tslib": "^2.3.0",
		"tsx": "^4.21.0",
		"typescript": "~5.9.2",
		"typescript-eslint": "^8.50.0",
		"vite": "^6.3.0",
		"vitest": "^4.0.16",
		"webpack": "^5.104.1"
	},
	"nx": {
		"includedScripts": [
			"format",
			"format:check"
		],
		"targets": {
			"lint": {
				"command": "echo 'No-op: Nx infers this target from the root eslint.config.mjs via @nx/eslint/plugin. Each project runs its own lint target. See issue #374.'"
			},
			"check": {
				"executor": "nx:run-commands",
				"cache": false,
				"options": {
					"parallel": false,
					"commands": [
						"node scripts/check-no-env-files.mjs",
						"node scripts/check-no-issue-refs-in-comments.mjs",
						"prettier --check --cache ."
					]
				}
			}
		}
	}
}
