{
	"$schema": "https://json-schema.org/schema",
	"id": "store",
	"title": "Generate Signal Store",
	"type": "object",
	"properties": {
		"name": {
			"type": "string",
			"description": "Entity name (camelCase, e.g. 'products')",
			"$default": { "$source": "argv", "index": 0 }
		},
		"directory": {
			"type": "string",
			"description": "Target directory relative to app src",
			"default": "src/app/store"
		},
		"project": { "type": "string", "description": "Target app directory" }
	},
	"required": ["name"]
}
