{
	"$schema": "https://json-schema.org/schema",
	"id": "drizzle-schema",
	"title": "Generate Drizzle Schema",
	"type": "object",
	"properties": {
		"name": {
			"type": "string",
			"description": "Table name (snake_case, e.g. 'product')",
			"$default": { "$source": "argv", "index": 0 }
		},
		"directory": { "type": "string", "description": "Target directory", "default": "src/db/schema" }
	},
	"required": ["name"]
}
