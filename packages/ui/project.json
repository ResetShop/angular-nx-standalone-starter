{
	"name": "ui",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": "packages/ui/src",
	"projectType": "library",
	"prefix": "rs",
	"tags": ["type:ui", "scope:starter"],
	"targets": {
		"test": {
			"executor": "@nx/vitest:test",
			"outputs": ["{workspaceRoot}/coverage/packages/ui"],
			"options": {
				"config": "packages/ui/vitest.config.ts"
			}
		},
		"typecheck": {
			"executor": "nx:run-commands",
			"cache": true,
			"inputs": ["{projectRoot}/**/*.ts", "{projectRoot}/tsconfig*.json", "sharedGlobals"],
			"options": {
				"command": "tsc --noEmit -p packages/ui/tsconfig.spec.json"
			}
		},
		"lint": {
			"executor": "@nx/eslint:lint",
			"options": {
				"lintFilePatterns": ["packages/ui/src/**/*.ts"]
			}
		},
		"stylelint": {
			"executor": "nx-stylelint:lint",
			"outputs": ["{options.outputFile}"],
			"options": {
				"lintFilePatterns": ["packages/ui/src/**/*.css"]
			}
		}
	}
}
