meta {
  name: Change Password - Validation Error
  type: http
  seq: 12
}

post {
  url: {{baseUrl}}/auth/change-password
  body: json
  auth: none
}

body:json {
  {
    "oldPassword": "your-current-password",
    "newPassword": "short"
  }
}

docs {
  # Change Password - Validation Error

  Tests that a new password shorter than the minimum length (12) is rejected with a 400.
}

assert {
  res.status: eq 400
}

tests {
  test("should return 400 for a too-short new password", function() {
    expect(res.status).to.equal(400);
  });
}
