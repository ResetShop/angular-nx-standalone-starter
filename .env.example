NODE_ENV=development
PG_CONNECTION_STRING=postgresql://user:password@localhost:5432/database

# Paseto & Access/Refresh Token Configuration
PASETO_SECRET_KEY=          # 32+ bytes hex string. Generate with: openssl rand -hex 32
PASETO_ACCESS_TOKEN_EXPIRY=1m
PASETO_REFRESH_TOKEN_EXPIRY=5m
PASETO_CLOCK_TOLERANCE=1m
PASETO_ISSUER=reset-shop
COOKIE_SECURE=false

# Email Provider Selection
# Controls which email transport is used at container startup.
#   smtp     — (default) Real SMTP delivery via Nodemailer. Requires SMTP_* vars below.
#   ethereal — Nodemailer's test service. No config needed; generates test credentials
#              automatically and logs preview URLs to the console.
EMAIL_PROVIDER=smtp

# SMTP Configuration (required when EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.example.com
SMTP_USER=user@example.com
SMTP_PASS=
SMTP_PORT=587              # optional, default: 587
SMTP_SECURE=false          # optional, set to 'true' for TLS on port 465
SMTP_FROM=noreply@example.com  # optional, default: noreply@example.com
